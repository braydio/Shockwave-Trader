# Public Brokerage API Configuration
# Use either an access token directly or a secret key that Arbiter can exchange for one.
PUBLIC_API_ACCESS_TOKEN=your_public_access_token_here
PUBLIC_API_SECRET_KEY=
PUBLIC_API_KEY=
PUBLIC_API_BASE=https://api.public.com
PUBLIC_ACCOUNT_ID=

# Execution Settings
MAX_POSITION_PCT=0.2
COOLDOWN_HOURS=4
MAX_DAILY_TRADES=10
DEFAULT_TRADE_AMOUNT=500
PAPER_STARTING_CASH=10000
PAPER_STATE_FILE=storage/paper_account.json

# Signal Thresholds
MIN_CONFIDENCE=0.7
MIN_MAGNITUDE=0.5

# Scheduler
CYCLE_INTERVAL_SECONDS=300

# OpenAI advisor (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_TIMEOUT_SECONDS=45
OPENAI_ADVISOR_ENABLED=false

# Free API Keys (get from respective sites)
FRED_API_KEY=your_fred_api_key
EIA_API_KEY=your_eia_api_key

# ═══════════════════════════════════════════════════════════
# TELEGRAM SETUP (MTProto — User Session, NOT Bot API)
# ═══════════════════════════════════════════════════════════
# STEP 1: Get credentials at https://my.telegram.org
#   → API development tools → Get api_id and api_hash
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=arbiter

# STEP 2: Add channel usernames or IDs to monitor
#   Format: @channel_username or -1001234567890 (numeric ID)
#   Separate multiple channels with commas
#   You MUST be a member of each channel to read messages
TELEGRAM_SOURCE_CHATS=@OilEnergyAlerts,@CrudeOilNews,@geopoliticsnow

# STEP 3: First run will ask for a phone verification code
#   The session file is saved to storage/arbiter.session
#   After first login, subsequent runs are fully automated

# ─── Bot API fallback (if MTProto not configured) ─────────
# Only works if your bot is IN the channel — limited use
TELEGRAM_BOT_TOKEN=

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
DISCORD_NOTIFICATIONS_ENABLED=true
DISCORD_SIGNALS_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_SIGNAL_CHANNELS=

# Execution Backend: public, paper, or auto (default - auto-detect)
EXECUTION_BACKEND=public

# Storage
STORAGE_DIR=storage
LOG_DIR=storage/logs
